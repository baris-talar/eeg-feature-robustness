# ── Large data files ──────────────────────────────────────────────────────────
# Raw EEG data (downloaded automatically via MOABB — do not commit)
data/*.edf
data/*.gdf
data/*.mat
data/*.hdf5
data/external/

# Feature matrices and epoch arrays (regenerated by pipeline — too large for git)
results/*.npy

# Results policy:
# ignore everything under results/ by default, then whitelist canonical
# publication artifacts (JSON sources of truth at the root, plus PNGs / CSVs
# under their dedicated subfolders).
results/*
!results/README.md
!results/*.json
!results/figures/
results/figures/*
!results/figures/*.png
!results/tables/
results/tables/*
!results/tables/*.csv
!results/metadata/
results/metadata/*
!results/metadata/*.csv

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.lof
paper/*.lot
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk
texput.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.coverage
.mypy_cache/
.pytest_cache/
.ruff_cache/
.cache/
htmlcov/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
.conda-env/
venv/
env/
.env

# ── MNE / MOABB cache ─────────────────────────────────────────────────────────
~/mne_data/
MNE-*-data/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
